{
  "source_folders": [
    "{HOME}/Downloads",
    "{HOME}/Desktop"
  ],
  "favorite_folders": [
    "{HOME}/Downloads"
  ],
  "warn_system_path": true,
  "scan_subfolders": false,
  "hide_unsupported": true,
  "rules": [
    {
      "category": "Documents",
      "target_folder": "{HOME}/Documents/Texts",
      "extensions": [".doc", ".docx", ".pdf", ".txt", ".rtf", ".odt", ".epub", ".pages", ".tex", ".md", ".mobi", ".azw3", ".log", ".csv"],
      "keywords": []
    },
    {
      "category": "Spreadsheets",
      "target_folder": "{HOME}/Documents/Spreadsheets",
      "extensions": [".xls", ".xlsx", ".ods", ".numbers", ".tsv", ".xlsm"],
      "keywords": []
    },
    {
      "category": "Presentations",
      "target_folder": "{HOME}/Documents/Presentations",
      "extensions": [".ppt", ".pptx", ".odp", ".key", ".ppsx"],
      "keywords": []
    },
    {
      "category": "Images & Photos",
      "target_folder": "{HOME}/Pictures",
      "extensions": [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".svg", ".webp", ".tiff", ".ico", ".heic", ".cr2", ".nef", ".psd", ".ai", ".eps", ".indd"],
      "keywords": []
    },
    {
      "category": "Videos",
      "target_folder": "{HOME}/Videos",
      "extensions": [".mp4", ".mkv", ".avi", ".mov", ".wmv", ".flv", ".webm", ".m4v", ".ts", ".vob", ".3gp", ".rmvb"],
      "keywords": []
    },
    {
      "category": "Audio & Music",
      "target_folder": "{HOME}/Music",
      "extensions": [".mp3", ".wav", ".flac", ".aac", ".ogg", ".m4a", ".wma", ".midi", ".mid", ".aiff", ".alac", ".amr"],
      "keywords": []
    },
    {
      "category": "Archives & Disk Images",
      "target_folder": "{HOME}/Downloads/Archives",
      "extensions": [".zip", ".rar", ".7z", ".tar", ".gz", ".bz2", ".xz", ".iso", ".dmg", ".vdi", ".vmdk", ".pkg"],
      "keywords": []
    },
    {
      "category": "Programs & Installers",
      "target_folder": "{HOME}/Downloads/Programs",
      "extensions": [".exe", ".msi", ".apk", ".app", ".deb", ".rpm", ".sh", ".bat", ".cmd", ".jar"],
      "keywords": []
    },
    {
      "category": "Web & Config",
      "target_folder": "{HOME}/Documents/Config",
      "extensions": [".html", ".htm", ".css", ".js", ".json", ".xml", ".yaml", ".yml"],
      "keywords": []
    },
    {
      "category": "Source Code",
      "target_folder": "{HOME}/Documents/Code",
      "extensions": [".go", ".py", ".java", ".cpp", ".c", ".h", ".cs", ".php", ".ts", ".sql", ".rb", ".swift"],
      "keywords": []
    },
    {
      "category": "Fonts",
      "target_folder": "{HOME}/Documents/Fonts",
      "extensions": [".ttf", ".otf", ".woff", ".woff2"],
      "keywords": []
    },
    {
      "category": "3D & CAD",
      "target_folder": "{HOME}/Documents/3D_CAD",
      "extensions": [".dwg", ".dxf", ".skp", ".obj", ".stl", ".fbx", ".blend", ".3ds"],
      "keywords": []
    }
  ]
}
