{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JazaSort",
  "version": "0.1.0",
  "identifier": "com.jazasort.app",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "JazaSort",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "build/windows/icon.ico"
    ]
  }
}
