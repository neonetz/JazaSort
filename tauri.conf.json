{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JazaSort",
  "version": "0.1.0",
  "identifier": "com.jazasort.app",
  "build": {
    "beforeBuildCommand": "npm --prefix frontend run build",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "frontendDist": "./frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "JazaSort",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
